# Application Settings
APP_NAME="NyayaSetu AI Platform"
APP_VERSION="0.1.0"
DEBUG=True

# API Settings
API_V1_PREFIX="/api/v1"
HOST="0.0.0.0"
PORT=8000

# AWS Bedrock Configuration (bearer token only)
AWS_REGION="ap-south-1"
AWS_BEARER_TOKEN_BEDROCK="your-bedrock-bearer-token"
# Use inference profile ID for Nova on-demand: global.* (ap-south-1) or us.amazon.nova-2-lite-v1:0 (us-east-1)
BEDROCK_MODEL_ID="global.amazon.nova-2-lite-v1:0"

# MongoDB Configuration
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="nyayasetu"

# Neo4j Configuration
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your-neo4j-password"

# Redis Configuration
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_URL="redis://localhost:6379/0"
REDIS_BROKER_URL="redis://localhost:6380/0"
REDIS_PUBSUB_URL="redis://localhost:6381/0"

# Security
SECRET_KEY="your-secret-key-change-in-production-use-openssl-rand-hex-32"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload Settings
MAX_UPLOAD_SIZE=16777216  # 16MB in bytes
ALLOWED_EXTENSIONS=["pdf", "jpg", "jpeg", "png"]

# De-identification (leave empty to use prompt next to app/ai/prompts/system/deidentification.txt)
DOC_FOLDER="doc"
